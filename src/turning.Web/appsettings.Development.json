        <InputText id="register-fullname" class="form-input" @bind-Value="_model.FullName" autocomplete="name" />
        <ValidationMessage For="@(() => _model.FullName)" />
      </div>

      <div class="form-field">
        <label class="form-label" for="register-email">Correo</label>
        <InputText id="register-email" class="form-input" @bind-Value="_model.Email" autocomplete="username" />
        <ValidationMessage For="@(() => _model.Email)" />
      </div>

      <div class="form-field">
        <label class="form-label" for="register-password">Contrasena</label>
        <InputText id="register-password" class="form-input" @bind-Value="_model.Password" type="password" autocomplete="new-password" />
        <ValidationMessage For="@(() => _model.Password)" />
      </div>

      <div class="form-field">
        <label class="form-label" for="register-confirm-password">Confirmar contrasena</label>
