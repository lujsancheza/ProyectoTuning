@inject NavigationManager NavigationManager
@inject TokenAuthenticationStateProvider AuthStateProvider

@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="top-row-label">Turning Web</span>
            <AuthorizeView Context="authState">
                <Authorized>
                    <span class="session-chip">@authState.User.Identity?.Name</span>
                    <a href="workspace">Panel</a>
                    <a href="unity">Unity Assets</a>
                    <button class="top-row-button" @onclick="HandleLogoutAsync">Cerrar sesion</button>
                </Authorized>
                <NotAuthorized>
                    <a href="login">Login</a>
                    <a href="register">Registro</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private async Task HandleLogoutAsync()
    {
        await AuthStateProvider.SignOutAsync();
        NavigationManager.NavigateTo("/login", replace: true);
    }
}
