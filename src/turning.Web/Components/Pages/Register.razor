@page "/register"

@inject AuthApiClient AuthApiClient
@inject NavigationManager NavigationManager
@inject TokenAuthenticationStateProvider AuthStateProvider

<PageTitle>Registro</PageTitle>

<section class="auth-shell">
    <article class="auth-panel">
        <p class="eyebrow">Registro</p>
        <h1>Crea una cuenta y entra al recorrido autenticado.</h1>
        <p class="hero-copy">
            El registro crea el usuario en base de datos, inicia sesion con el JWT devuelto por la API y deja
            preparado el estado local de Blazor para navegar sin refrescos manuales.
        </p>

        <div class="feature-grid">
            <article class="info-card">
                <span class="card-tag">Dominio</span>
                <h2>Cuenta persistida</h2>
                <p>El alta va directo al endpoint de registro ya implementado en la API y respeta la capa backend existente.</p>
            </article>

            <article class="info-card">
                <span class="card-tag">Seguridad</span>
                <h2>Navegacion interna segura</h2>
                <p>El retorno despues del alta solo acepta rutas internas para evitar redirecciones externas no deseadas.</p>
            </article>
        </div>
    </article>

    <article class="auth-form-card">
        <div class="auth-card-header">
            <p class="eyebrow">Nuevo acceso</p>
            <h2>Registrar usuario</h2>
            <p>El rol inicial queda fijado como Researcher para mantener el primer flujo simple y consistente.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="auth-alert auth-alert-error">@_errorMessage</div>
        }

        <EditForm FormName="register-form" Model="_model" OnValidSubmit="HandleSubmitAsync" class="auth-form">
            <DataAnnotationsValidator />

            <div class="form-field">
                <label class="form-label" for="register-fullname">Nombre completo</label>
                <InputText id="register-fullname" class="form-input" @bind-Value="_model.FullName" autocomplete="name" />
                <ValidationMessage For="@(() => _model.FullName)" />
            </div>

            <div class="form-field">
                <label class="form-label" for="register-email">Correo</label>
                <InputText id="register-email" class="form-input" @bind-Value="_model.Email" autocomplete="username" />
                <ValidationMessage For="@(() => _model.Email)" />
            </div>

            <div class="form-field">
                <label class="form-label" for="register-password">Contrasena</label>
                <InputText id="register-password" class="form-input" @bind-Value="_model.Password" type="password" autocomplete="new-password" />
                <ValidationMessage For="@(() => _model.Password)" />
            </div>

            <div class="form-field">
                <label class="form-label" for="register-confirm-password">Confirmar contrasena</label>
                <InputText id="register-confirm-password" class="form-input" @bind-Value="_model.ConfirmPassword" type="password" autocomplete="new-password" />
                <ValidationMessage For="@(() => _model.ConfirmPassword)" />
            </div>

            <button class="hero-button hero-button-primary auth-submit" type="submit" disabled="@_isSubmitting">
                @(_isSubmitting ? "Creando cuenta..." : "Crear cuenta")
            </button>
        </EditForm>

        <p class="auth-link-line">
            Ya tienes acceso? <a href="@BuildLoginLink()">Ir al login</a>
        </p>
        <p class="auth-footnote">Registro persistido · auto-login · retorno protegido</p>
    </article>
</section>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly RegisterInputModel _model = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    private async Task HandleSubmitAsync()
    {
        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            var authResult = await AuthApiClient.RegisterAsync(new RegisterRequestDto
            {
                FullName = _model.FullName.Trim(),
                Email = _model.Email.Trim(),
                Password = _model.Password
            });

            await AuthStateProvider.SignInAsync(authResult);
            NavigationManager.NavigateTo(ResolveReturnUrl(), replace: true);
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string BuildLoginLink()
    {
        return $"/login?returnUrl={Uri.EscapeDataString(ResolveReturnUrl())}";
    }

    private string ResolveReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/workspace";
        }

        if (ReturnUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            || ReturnUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            || ReturnUrl.StartsWith("//", StringComparison.Ordinal))
        {
            return "/workspace";
        }

        return ReturnUrl.StartsWith("/", StringComparison.Ordinal) ? ReturnUrl : $"/{ReturnUrl}";
    }

    private sealed class RegisterInputModel
    {
        [Required(ErrorMessage = "El nombre es obligatorio.")]
        public string FullName { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo es obligatorio.")]
        [EmailAddress(ErrorMessage = "Debes escribir un correo valido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contrasena es obligatoria.")]
        [MinLength(6, ErrorMessage = "La contrasena debe tener al menos 6 caracteres.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Debes confirmar la contrasena.")]
        [Compare(nameof(Password), ErrorMessage = "Las contrasenas no coinciden.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}